# ============================================================
# scoop-booking | environment variables
# Copy to .env for local dev. NEVER commit .env.
# In production these are set as Coolify env vars, not from a file.
# ============================================================

# Port Coolify maps the domain to. Defaults to 3000 if unset.
PORT=3000

# ---------- Meta Pixel + Conversions API ----------
# Pixel ID is public (also in the page <head>). The CAPI token is a SECRET — env only, never in client code or git.
META_PIXEL_ID=
META_CAPI_TOKEN=

# Optional: routes /api/lead events to Events Manager > Test Events so production data stays clean.
# META_TEST_EVENT_CODE=

# ---------- GHL CRM (Scoop sub-account on the Kaizen white-label) ----------
# PIT = location Private Integration Token (contacts scope). SECRET — env only, never in git.
# Source of truth is the Lighthouse Client.ghlPit column for slug scoop-pilates.
GHL_PIT=
GHL_LOCATION_ID=ll5FjMyc9NTEDpflcgi9

# ---------- GymMaster (Scoop member system) ----------
# Enrols the lead into the Free Trial pass on submit. api_key = the GymMaster portal/staff key. SECRET.
# Membership is selected by membershiptypeid (190009 = Free Trial), NOT membership_id (ignored by GymMaster).
GM_API_KEY=
GM_BASE_URL=https://scooppilates.gymmasteronline.com
GM_MEMBERSHIPTYPEID=190009
GM_COMPANY_ID=2
GM_DEFAULT_DOB=2000-01-01
